{
  "service": "worker1-weather-compare",
  "transport": "http-json",
  "base_path": "/api/weather",
  "endpoints": [
    {
      "name": "health",
      "method": "GET",
      "path": "/health",
      "response": {
        "status": "ok",
        "worker_id": "ubuntu-worker-01",
        "timestamp_utc": "ISO8601"
      }
    },
    {
      "name": "compare",
      "method": "POST",
      "path": "/compare",
      "request": {
        "city_a": "San Diego",
        "city_b": "New York City",
        "units": "metric"
      },
      "response": {
        "request_id": "string",
        "timestamp_utc": "ISO8601",
        "city_a": {
          "name": "string",
          "temp_c": 0,
          "humidity_pct": 0,
          "wind_kph": 0,
          "condition": "string"
        },
        "city_b": {
          "name": "string",
          "temp_c": 0,
          "humidity_pct": 0,
          "wind_kph": 0,
          "condition": "string"
        },
        "comparison": {
          "temp_delta_c": 0,
          "humidity_delta_pct": 0,
          "wind_delta_kph": 0,
          "condition_match": false,
          "summary": "string"
        },
        "source": "provider-name"
      }
    }
  ]
}
